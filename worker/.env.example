APP_ENV=development
WORKER_HOST=127.0.0.1
WORKER_PORT=8000

# Supabase project APIs
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Direct Postgres connection for persistent worker traffic.
# Supabase recommends a connection string for backend Postgres clients.
SUPABASE_DB_URL=postgresql://postgres:your-password@aws-0-your-region.pooler.supabase.com:5432/postgres

# Neo4j AuraDB connection
NEO4J_URI=neo4j+s://your-instance-id.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password
